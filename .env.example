# ===========================================================================
# Smart Money Consensus Trader — environment variables
# ===========================================================================
# All of these are SERVER-ONLY. Never expose them to a browser, never commit a
# filled-in copy, never log them, never return them through an API.
# ---------------------------------------------------------------------------

# --- Polymarket US API credentials (Ed25519) -------------------------------
# Generate at https://polymarket.us/developer
POLYMARKET_KEY_ID=
POLYMARKET_SECRET_KEY=

# --- Trading mode & safety switches ----------------------------------------
# TRADING_MODE: paper | approval | live   (default: paper)
TRADING_MODE=paper
# Live execution requires BOTH TRADING_MODE=live AND POLYMARKET_LIVE_TRADING=true
POLYMARKET_LIVE_TRADING=false

# --- Position sizing & exposure limits (USD) -------------------------------
MAX_TRADE_USD=2
MAX_MARKET_EXPOSURE_USD=4
MAX_TOTAL_EXPOSURE_USD=20
MAX_DAILY_LOSS_USD=5
MAX_OPEN_POSITIONS=5
MAX_TRADES_PER_DAY=10
MIN_CASH_RESERVE_USD=20

# --- Consensus thresholds --------------------------------------------------
MIN_CONSENSUS_TRADERS=3
MIN_CONSENSUS_SCORE=75

# --- Database (Railway Postgres) -------------------------------------------
# Railway injects DATABASE_URL automatically when you attach a Postgres plugin.
DATABASE_URL=

# --- Admin dashboard -------------------------------------------------------
# Long random string. Requests to the admin API must send this as a bearer
# token (Authorization: Bearer <token>) or the x-admin-token header.
ADMIN_TOKEN=
# Port the admin HTTP server binds to (Railway sets PORT automatically).
PORT=8080

# --- Worker tuning (optional; sensible defaults applied) --------------------
# Main worker cycle interval in milliseconds.
WORKER_CYCLE_MS=60000
# How often to reconcile API vs DB state, in milliseconds.
RECONCILE_INTERVAL_MS=300000
# Per-market cooldown after a trade, in minutes.
TRADE_COOLDOWN_MINUTES=60
# Consensus is considered stale if newest supporting entry is older than this
# many hours.
CONSENSUS_MAX_AGE_HOURS=72
# Number of leaderboard traders to analyze per period.
LEADERBOARD_SIZE=25

# --- Exit policy (optional; sensible defaults applied) ----------------------
TAKE_PROFIT_PCT=25
STOP_LOSS_PCT=20
MAX_HOLD_HOURS=168
APPROACHING_RESOLUTION_HOURS=6
MIN_EXIT_LIQUIDITY_USD=50

# --- Public Polymarket data endpoints (best-effort; override if they move) --
# Used only for leaderboard rankings and public trader positions/trades, which
# are not exposed through the authenticated US SDK. All mappings back to a US
# market are verified strictly before any trade.
PUBLIC_DATA_API_BASE=https://data-api.polymarket.com
PUBLIC_LEADERBOARD_API_BASE=https://lb-api.polymarket.com
# Set to "true" to disable all external public-API calls (worker still runs
# reconciliation, exits, and risk management on existing positions).
DISABLE_PUBLIC_API=false
