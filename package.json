{
  "name": "smart-money-consensus-trader",
  "version": "0.1.0",
  "private": true,
  "description": "Always-on Smart Money Consensus Trader for Polymarket US — ranks traders by risk-adjusted returns, detects consensus, and places very small proof-of-concept trades.",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('src/db/schema.sql','dist/db/schema.sql');require('fs').cpSync('src/admin/public','dist/admin/public',{recursive:true})\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "worker": "node dist/worker/index.js",
    "worker:dev": "tsx watch src/worker/index.ts",
    "admin": "node dist/admin/index.js",
    "admin:dev": "tsx watch src/admin/index.ts",
    "migrate": "node dist/db/migrate.js",
    "migrate:dev": "tsx src/db/migrate.ts",
    "start": "npm run migrate && npm run worker",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "polymarket-us": "^0.1.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
